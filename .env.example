# Copy to .env and fill in before running
# DO NOT commit .env to git

# Data paths
DATA_DIR=./data/raw
DB_PATH=./data/db/quant_v2.db
PINE_DIR=./data/pine_scripts
CHECKLIST_DIR=./data/checklists

# IS/OOS date splits -- DO NOT CHANGE after first use (invalidates all results)
IS_START=2020-01-01
IS_TRAIN_END=2022-12-31
IS_VAL_END=2023-12-31
OOS_START=2024-01-01

# Trading constants
COMMISSION_RT=3.40

# Pipeline thresholds
SCREEN_MIN_PF=1.3
SCREEN_MIN_TRADES=30
OOS_MIN_PF=1.5
OOS_MIN_TRADES=100
OOS_MAX_DD_PCT=40.0
MC_MIN_P_POSITIVE=0.95
MC_MAX_P_RUIN=0.01
IS_OPT_MIN_SHARPE=0.5
IS_OPT_MIN_PF=1.2
CONFIRM_MAX_CORR=0.6
CROSS_MIN_TRADES=50

# Optuna
OPTUNA_TRIALS=300
OPTUNA_EARLY_STOP=50
N_WORKERS=-1

# Automation
AUTOSTART_RUNNER=false
POLL_INTERVAL=60
